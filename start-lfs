#!/usr/bin/env bash
# Ensure the I40-Stack Docker stack is running, then launch the LineFeed Simulator.
# Auto-selects the correct compose file for the current platform.
# Skips image pull for fast repeat starts.
set -euo pipefail

LFS_DIR="$(cd "$(dirname "$0")" && pwd)"
I40_DIR="$(cd "$LFS_DIR/../I40-Stack" && pwd)"

arch=$(uname -m)
os=$(uname -s)

if [[ "$arch" == "arm64" ]]; then
    COMPOSE_FILE="docker-compose.m3.yml"
elif [[ "$arch" == "x86_64" && "$os" == "Darwin" ]]; then
    COMPOSE_FILE="docker-compose.x86_64.yml"
elif [[ "$arch" == "x86_64" && "$os" == "Linux" ]]; then
    COMPOSE_FILE="docker-compose.x86_64.yml"
else
    echo "ERROR: Unsupported platform: $os/$arch" >&2
    exit 1
fi

CONTAINERS=(i40-mosquitto i40-influxdb i40-telegraf i40-grafana i40-nodered i40-ignition)

# ---------------------------------------------------------------------------
# Pre-flight
# ---------------------------------------------------------------------------
if [ ! -f "$I40_DIR/.env" ]; then
    echo "ERROR: $I40_DIR/.env not found." >&2
    echo "  Run: cp $I40_DIR/.env.template $I40_DIR/.env  and fill in values." >&2
    exit 1
fi

if ! docker info &>/dev/null; then
    echo "ERROR: Docker daemon is not running." >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Check which containers are already running
# ---------------------------------------------------------------------------
not_running=()
for name in "${CONTAINERS[@]}"; do
    status=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "missing")
    if [[ "$status" != "running" ]]; then
        not_running+=("$name ($status)")
    fi
done

if [[ ${#not_running[@]} -eq 0 ]]; then
    echo "All containers already running."
else
    echo "Platform: $os/$arch"
    echo "Compose:  $COMPOSE_FILE"
    echo "Starting containers (skipping pull)..."
    cd "$I40_DIR"
    docker compose -f "$COMPOSE_FILE" up -d --no-build --remove-orphans
fi

# ---------------------------------------------------------------------------
# Status summary
# ---------------------------------------------------------------------------
echo ""
printf "%-20s %s\n" "CONTAINER" "STATUS"
printf "%-20s %s\n" "---------" "------"
for name in "${CONTAINERS[@]}"; do
    status=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "missing")
    printf "%-20s %s\n" "$name" "$status"
done

echo ""
echo "  InfluxDB    http://localhost:8181"
echo "  Telegraf    (internal)"
echo "  Grafana     http://localhost:3000"
echo "  Node-RED    http://localhost:1881"
echo "  Ignition    http://localhost:8088"
echo ""

# ---------------------------------------------------------------------------
# Launch simulator
# ---------------------------------------------------------------------------
cd "$LFS_DIR"
echo "Starting LineFeed Simulator..."
exec uv run python main.py "$@"
